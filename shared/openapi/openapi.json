      },
      "ProviderHealth": {
        "properties": {
          "provider": {
            "type": "string",
            "title": "Provider"
          },
          "available": {
            "type": "boolean",
            "title": "Available"
          },
          "status": {
            "$ref": "#/components/schemas/HealthStatus"
