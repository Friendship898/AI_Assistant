            "default": null,
            "title": "Binary Ref"
          },
          "metadata": {
            "additionalProperties": true,
            "title": "Metadata",
            "type": "object"
          }
        },
        "required": [
          "id",
          "source"
        ],
        "title": "ContextItem",
        "type": "object"
      },
