          },
          "selected_provider": {
            "title": "Selected Provider",
            "type": "string"
          },
          "selected_model": {
            "title": "Selected Model",
            "type": "string"
          },
          "context_summary": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "default": null,
            "title": "Context Summary"
          },
          "metadata": {
            "additionalProperties": true,
            "title": "Metadata",
            "type": "object"
          }
