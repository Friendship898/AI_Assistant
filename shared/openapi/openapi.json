      "TaskType": {
        "enum": [
          "text_rewrite",
          "text_summary",
          "text_generation",
          "qna_general",
          "qna_factual",
          "code_explain",
          "code_generate",
          "code_review",
          "code_debug",
          "search_required",
          "reasoning_simple",
          "reasoning_complex",
          "planning",
          "multi_doc",
          "translation",
          "chat",
          "doc_library_query",
          "file_modification"
