            "type": "array"
          },
          "history": {
            "items": {
              "$ref": "#/components/schemas/ChatMessage"
            },
            "title": "History",
            "type": "array"
          },
          "options": {
            "$ref": "#/components/schemas/GenerationOptions"
          }
