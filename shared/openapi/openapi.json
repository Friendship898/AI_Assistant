      "ChatResponse": {
        "properties": {
          "session_id": {
            "title": "Session Id",
            "type": "string"
          },
          "message_id": {
            "title": "Message Id",
            "type": "string"
          },
          "reply": {
            "$ref": "#/components/schemas/ChatMessage"
          },
          "route_result": {
            "$ref": "#/components/schemas/RouteResult"
          },
          "usage": {
            "anyOf": [
              {
                "$ref": "#/components/schemas/TokenUsage"
