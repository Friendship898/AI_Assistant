{
  "openapi": "3.1.0",
  "info": {
    "title": "AI Desktop Assistant Backend",
    "version": "0.1.0"
  },
  "paths": {
    "/api/v1/health": {
      "get": {
        "tags": [
          "health"
        ],
        "summary": "Get Health",
        "operationId": "get_health_api_v1_health_get",
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HealthApiResponse"
                }
              }
            }
          }
        }
      }
    }
  },
